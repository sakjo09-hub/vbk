# --- Тестовый режим (SQLite) ---
DATABASE_URL=sqlite+aiosqlite:///./betting.db
DATABASE_URL_SYNC=sqlite:///./betting.db

# --- Продакшн (PostgreSQL) ---
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/betting_virtual
# DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/betting_virtual

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

VIRTUAL_CURRENCY_CODE=VC
VIRTUAL_STARTING_BALANCE=10000

# mock (тестовые данные) | odds_api (реальные коэффициенты The Odds API) | parser (парсинг БК) | pandascore (PandaScore)
FOOTBALL_PROVIDER=odds_api
DOTA_PROVIDER=odds_api

# The Odds API: бесплатный ключ на https://the-odds-api.com
ODDS_API_KEY=
ODDS_API_BASE=https://api.the-odds-api.com/v4
ODDS_API_REGIONS=eu
ODDS_API_FOOTBALL_SPORTS=soccer_epl,soccer_uefa_champs_league
ODDS_API_DOTA_SPORTS=

# PandaScore: бесплатный Hobby-тариф на https://pandascore.co (1000 запросов/мес)
PANDASCORE_API_KEY=

SCHEDULER_FETCH_INTERVAL_MINUTES=240
SCHEDULER_SETTLE_INTERVAL_MINUTES=60
SETTLE_GRACE_MINUTES=120
